# ========================================
# OPENSEA BOT - KONFIGURASI
# ========================================
# Salin file ini menjadi .env dan isi nilainya
# JANGAN commit file .env ke GitHub!

# --- WALLET ---
PRIVATE_KEY=0xprivate_key_wallet_kamu_disini

# --- RPC PROVIDER (pilih salah satu) ---
# Alchemy: https://alchemy.com
# Infura:  https://infura.io
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/API_KEY_KAMU

# --- OPENSEA API ---
# Daftar di: https://opensea.io/developers
OPENSEA_API_KEY=opensea_api_key_kamu

# --- CHAIN ---
# Pilihan: ethereum, polygon, base, arbitrum, optimism, avalanche, klaytn, solana
CHAIN=ethereum

# --- HARGA LISTING ---
# Harga awal listing dalam ETH (atau native token chain)
DEFAULT_PRICE=0.05

# --- STRATEGI HARGA ---
# Apakah harga mengikuti floor price collection?
# true  = harga otomatis ikut floor price
# false = pakai DEFAULT_PRICE
FOLLOW_FLOOR_PRICE=true

# Offset harga dari floor price (dalam %)
# Contoh: -5 berarti listing 5% DIBAWAH floor price
# Contoh: 10 berarti listing 10% DIATAS floor price
PRICE_OFFSET_PERCENT=-5

# --- DURASI LISTING ---
# Berapa hari listing berlaku sebelum expired
LISTING_DURATION_DAYS=7

# --- JADWAL (format cron) ---
# Cek dan update listing setiap berapa lama?
# "*/30 * * * *"  = setiap 30 menit
# "0 * * * *"     = setiap 1 jam
# "0 */6 * * *"   = setiap 6 jam
CRON_SCHEDULE=0 * * * *

# --- CONTRACT NFT (opsional) ---
# Kosongkan jika ingin list SEMUA NFT di wallet
# Isi jika hanya ingin list dari collection tertentu
NFT_CONTRACT_ADDRESS=

# --- BATAS LISTING ---
# Maksimal berapa NFT yang dilist sekaligus (0 = tidak ada batas)
MAX_LISTINGS=0
