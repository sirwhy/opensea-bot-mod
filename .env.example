# ================================================================
#  OPENSEA MULTI-CHAIN BOT — KONFIGURASI
#  Salin file ini ke .env dan isi nilainya
#  JANGAN commit .env ke GitHub!
# ================================================================

# ── WALLET ──────────────────────────────────────────────────────
# Satu wallet:
PRIVATE_KEY=0xprivate_key_kamu

# Atau banyak wallet (pisah koma):
# PRIVATE_KEYS=0xkey1,0xkey2,0xkey3

# Atau pakai mnemonic 12/24 kata:
# MNEMONIC=word1 word2 word3 ... word12


# ── OPENSEA API ─────────────────────────────────────────────────
# Daftar di: https://opensea.io/developers
OPENSEA_API_KEY=opensea_api_key_kamu


# ── COLLECTIONS (WAJIB) ─────────────────────────────────────────
# Format: chain:collection-slug:0xContractAddress
# Pisah koma untuk multi-collection
#
# Contoh Arbitrum:
# COLLECTIONS=arbitrum:arbitrumdao-celebrating-the-third-anniversary:0xContractKamu
#
# Contoh multi-chain:
# COLLECTIONS=arbitrum:nama-collection:0xContract1,ethereum:bayc:0xBC4CA0EdA7647A8aB7C2061c2E118A18a936f13d
COLLECTIONS=arbitrum:nama-collection-kamu:0xContractAddressKamu


# ── RPC URL (OPSIONAL) ──────────────────────────────────────────
# Sudah ada public RPC default untuk semua chain.
# Isi hanya jika ingin pakai RPC custom (Alchemy, Infura, dll).
# Public RPC default per chain:
#   ethereum  → ethereum.publicnode.com
#   arbitrum  → arbitrum-one.publicnode.com
#   polygon   → polygon.publicnode.com
#   base      → base.publicnode.com
#   optimism  → optimism.publicnode.com
#   avalanche → avalanche-c-chain.publicnode.com
#   animechain→ rpc.animechain.ai
#   blast     → blast.publicnode.com
#   zora      → rpc.zora.energy

# Uncomment jika perlu override:
# RPC_URL_ETHEREUM=https://eth-mainnet.g.alchemy.com/v2/KEY
# RPC_URL_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/KEY
# RPC_URL_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/KEY
# RPC_URL_BASE=https://base-mainnet.g.alchemy.com/v2/KEY
# RPC_URL_ANIMECHAIN=https://rpc.animechain.ai


# ── HARGA ───────────────────────────────────────────────────────
# Harga SELALU mengikuti floor price collection
# Tidak perlu set DEFAULT_PRICE

# Offset dari floor price (dalam %)
# 0   = tepat di floor
# -2  = 2% di bawah floor
# 5   = 5% di atas floor
PRICE_OFFSET_PERCENT=0

# Harga minimum fallback HANYA jika floor price tidak bisa diambil sama sekali
# (biasanya tidak perlu diubah)
MIN_PRICE_FALLBACK=0.000001

# Batas atas harga (0 = tidak ada batas)
MAX_PRICE=0


# ── LISTING ─────────────────────────────────────────────────────
# Durasi listing dalam MENIT (bukan hari)
LISTING_DURATION_MINUTES=10

# Maksimal NFT dilist per wallet (0 = semua)
MAX_LISTINGS=0


# ── JADWAL ──────────────────────────────────────────────────────
# Default: setiap 10 menit (sinkron dengan durasi listing)
# "*/10 * * * *" = setiap 10 menit
# "*/5 * * * *"  = setiap 5 menit
# "* * * * *"    = setiap 1 menit
CRON_SCHEDULE=*/10 * * * *


# ── RETRY ───────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY_MS=3000


# ── DELAY ANTAR OPERASI ─────────────────────────────────────────
DELAY_BETWEEN_NFTS=2000
DELAY_AFTER_CANCEL=3000


# ── GAS PROTECTION ──────────────────────────────────────────────
# Skip listing jika gas > nilai ini Gwei (0 = tidak ada batasan)
MAX_GAS_PRICE_GWEI=0


# ── MANUAL TOKEN IDS (OPSIONAL) ─────────────────────────────────
# Jika diisi, bot hanya akan listing token-token ini
# (tetap verifikasi ownership realtime sebelum listing)
# TOKEN_IDS=1234,5678,9012


# ── MODE DEBUG ──────────────────────────────────────────────────
# DRY_RUN=true → simulasi tanpa transaksi nyata
DRY_RUN=false

# VERBOSE=true → tampilkan stack trace lengkap
VERBOSE=false

# ── TELEGRAM NOTIFICATIONS (OPSIONAL) ─────────────────────────────
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=8472449527:AAGlQJkp11FW-CL4Gh1MSuzYX5AEdSe2yP4
TELEGRAM_CHAT_ID=899391125
