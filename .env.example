# ========================================
# OPENSEA BOT - KONFIGURASI
# ========================================
# Salin file ini menjadi .env dan isi nilainya
# JANGAN commit file .env ke GitHub!

# --- WALLET ---
PRIVATE_KEY=0xprivate_key_wallet_kamu_disini

# --- RPC (OPSIONAL) ---
# Tidak perlu diisi! Bot akan menggunakan public RPC otomatis.
# Bisa isi beberapa RPC dipisah koma untuk failover
# RPC_URL=

# --- OPENSEA API ---
# Daftar di: https://opensea.io/developers
OPENSEA_API_KEY=opensea_api_key_kamu

# --- CHAIN ---
# Pilihan: ethereum, polygon, base, arbitrum, optimism, avalanche, bsc, celo, fantom, klaytn, animechain
CHAIN=arbitrum

# --- HARGA (OPSIONAL) ---
# Mode harga: "eth" atau "usd"
# Jika "usd", harga akan dikonversi ke ETH sesuai harga terkini
PRICE_MODE=eth

# Harga default (dalam ETH atau USD sesuai mode)
# Contoh: 0.01 ETH atau 50 USD
DEFAULT_PRICE=0.01
MIN_PRICE=0.001

# Langsung设定 floor price (dalam USD) - untuk mode USD
# Jika diisi, bot akan gunakan ini sebagai floor dan apply offset
# FLOOR_PRICE_USD=100

# --- STRATEGI HARGA ---
# Default: TRUE - harga otomatis ikut floor price
# Tidak perlu diset jika mau auto floor price
FOLLOW_FLOOR_PRICE=true

# Offset harga dari floor price (dalam %)
# Default: -10 (listing 10% DIBAWAH floor price)
PRICE_OFFSET_PERCENT=-10

# --- DURASI LISTING ---
# Default: 600 detik (10 menit) - lalu akan auto relist
LISTING_DURATION_SECONDS=600

# --- JADWAL (format cron) ---
# Default: */10 * * * * (cek setiap 10 menit)
CRON_SCHEDULE=*/10 * * * *

# --- CONTRACT NFT (opsional) ---
# Isi dengan contract address NFT yang mau di-list
# Contoh: 0x41fde438b6b757bc13f956464fd64b3a540692f0
NFT_CONTRACT_ADDRESS=0x41fde438b6b757bc13f956464fd64b3a540692f0

# --- COLLECTION SLUG (untuk floor price) ---
# Contoh: azuki, boredapeyachtclub, pudgypenguins
# Kosongkan jika tidak pakai floor price
COLLECTION_SLUG=

# --- TELEGRAM NOTIFICATIONS (opsional) ---
# Buat bot: @BotFather di Telegram
# Get chat ID: @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- BATAS LISTING ---
# Maksimal NFT yang dilist (0 = tidak ada batas)
MAX_LISTINGS=0